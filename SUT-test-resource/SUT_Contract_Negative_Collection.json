          "script": {
            "exec": [
              "pm.test(\"Login must be successful to continue workflow\", function () {\r",
              "    if (pm.response.code !== 200) {\r",
              "        console.error(\"Login failed! Halting the automation suite.\");\r",
              "        // Passing 'null' stops the Collection Runner completely\r",
              "        pm.execution.setNextRequest(null); \r",
              "    } else {\r",
              "        pm.expect(pm.response.code).to.eql(200);\r",
              "    }\r",
