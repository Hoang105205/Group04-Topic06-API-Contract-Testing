        {
          "name": "api/apply-coupon (JSON Schema Validation for Errors)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Define the JSON schema for error responses\r",
                  "const errSchema = {\r",
                  "  \"type\": \"object\",\r",
                  "  \"required\": [\"error\"],\r",
                  "  \"properties\": {\r",
                  "    \"error\": { \"type\": \"string\" }\r",
                  "  }\r",
                  "};\r",
                  "\r",
                  "// 2. Validate the response status code is 400 Bad Request (commonly used for errors)\r",
                  "pm.test(\"Status code is 400 Bad Request\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "// 3. Validate the response body against the error JSON schema\r",
                  "pm.test(\"Error response matches Error JSON Schema Contract\", function () {\r",
                  "    pm.response.to.have.jsonSchema(errSchema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"code\": \"SAVE10\",\r\n    \"total_amount\": 250000,\r\n    \"user_id\": 1\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/apply-coupon",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "apply-coupon"
              ]
            }
          },
          "response": []
