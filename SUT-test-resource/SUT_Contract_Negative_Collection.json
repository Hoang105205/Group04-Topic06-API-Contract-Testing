    {
      "name": "api/login (Brute-Force Protection & Account Lockout)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"API locks account after 3 failed login attempts\", function () {\r",
              "    // The status should be either 401 (Invalid password) or 403 (Locked)\r",
              "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);\r",
              "    \r",
              "    if (pm.response.code === 403) {\r",
              "        pm.expect(pm.response.json().error).to.include('Tài khoản đã bị khóa');\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
