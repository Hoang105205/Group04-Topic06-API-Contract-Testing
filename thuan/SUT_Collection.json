    {
      "name": "api/products (GET)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const products = pm.response.json();\r",
              "\r",
              "pm.test(\"Save First Product ID, Name & Price\", function () {\r",
              "    // Check if the array has items to avoid runtime errors\r",
              "    if(products.length > 0) {\r",
              "        pm.environment.set(\"product_id\", products[0].id);\r",
              "        pm.environment.set(\"product_name\", products[0].name);\r",
              "        pm.environment.set(\"product_price\", products[0].price);\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Validate Array Structure and Length\", function () {\r",
              "    const products = pm.response.json();\r",
              "    \r",
              "    // Ensure the response is explicitly an array format\r",
              "    pm.expect(products).to.be.an('array');\r",
              "    \r",
              "    // Ensure the array is not empty (length > 0)\r",
              "    pm.expect(products).to.not.be.empty;\r",
              "    \r",
              "    // Alternatively, if you expect an exact number of items, use lengthOf:\r",
              "    // pm.expect(products).to.have.lengthOf(10);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
