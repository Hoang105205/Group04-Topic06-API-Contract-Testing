    {
      "name": "api/login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseData = pm.response.json();\r",
              "\r",
              "pm.test(\"Save Auth Token and User ID\", function () {\r",
              "     pm.environment.set(\"auth_token\", responseData.token);\r",
              "     pm.environment.set(\"user_id\", responseData.user.id);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is acceptable (< 800ms)\", function () {\r",
              "    // Validates that the request took less than 800 milliseconds to complete\r",
              "    pm.expect(pm.response.responseTime).to.be.below(800);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate Login Schema, Data Types, and Nested Objects\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    // 1. Validate flat properties (root level)\r",
              "    pm.expect(responseData).to.be.an('object');\r",
              "    pm.expect(responseData).to.have.property('message').that.is.a('string');\r",
              "    pm.expect(responseData).to.have.property('token').that.is.a('string');\r",
              "    \r",
              "    // 2. Validate nested JSON objects (the 'user' object)\r",
              "    pm.expect(responseData).to.have.property('user').that.is.an('object');\r",
              "    \r",
              "    // 3. Drill down into the nested object's data types\r",
              "    pm.expect(responseData.user).to.have.property('id').that.is.a('number');\r",
              "    pm.expect(responseData.user).to.have.property('email').that.is.a('string');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
