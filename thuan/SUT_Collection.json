      "name": "api/cart (GET)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const cartItems = pm.response.json();\r",
              "\r",
              "pm.test(\"Calculate and Save Total Sum\", function () {\r",
              "    let total = 0;\r",
              "    \r",
              "    // Ensure the response is an array before calculating\r",
              "    if (Array.isArray(cartItems) && cartItems.length > 0) {\r",
              "        cartItems.forEach(item => {\r",
              "            total += item.price; \r",
              "        });\r",
              "    }\r",
              "    \r",
              "    pm.environment.set(\"sum_money\", total);\r",
              "});"
            ],
            "type": "text/javascript",
